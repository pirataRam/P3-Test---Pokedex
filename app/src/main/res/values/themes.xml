<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main Application Theme -->
    <style name="Theme.P3TestPokedex" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Theme for the Splash Screen using the official SplashScreen library -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">#F2F2F7</item>
        
        <!-- Set the splash screen icon (our beautiful Pokeball vector!) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        
        <!-- Set the post-splash screen activity theme -->
        <item name="postSplashScreenTheme">@style/Theme.P3TestPokedex</item>
    </style>
</resources>